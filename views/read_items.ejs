<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Items</title>
  <style>
    body {
      font-family: Arial, sans-serif;
      padding: 2rem;
    }
    h1 {
      margin-bottom: 1rem;
    }
    table {
      width: 100%;
      border-collapse: collapse;
    }
    th, td {
      padding: 0.75rem;
      border: 1px solid #ddd;
      text-align: left;
    }
    th {
      background-color: #f4f4f4;
    }
    .empty {
      color: #777;
      margin-top: 1rem;
    }
  </style>
</head>
<body>
    <button onclick="history.back()">← Back</button>
  <h1>Items</h1>

  <% if (items && items.length > 0) { %>
    <table>
      <thead>
        <tr>
          <th>Name</th>
          <th>Category</th>
        </tr>
      </thead>
      <tbody>
        <% items.forEach(item => { %>
          <tr>
            <td><%= item.name %></td>
            <td><%= item.category_name %></td>
            <td>
            <a href="/items/<%= item.id %>/edit"><button>Update</button></a>
            <form action="/items/<%= item.id %>/delete" method="POST" style="display:inline;">
              <button type=submit>Delete</button>
            </form>
          </td>

          </tr>
        <% }) %>
      </tbody>
    </table>
  <% } else { %>
    <p class="empty">No items found.</p>
  <% } %>
    <a href="/items/new"><button>Add item</button></a>

</body>
</html>
